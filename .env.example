# MongoDB connection string (Atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/nikolator?retryWrites=true&w=majority

# JWT secrets (generar con: openssl rand -base64 64)
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Puerto del servidor (Render lo asigna automáticamente en producción)
PORT=3000

# Orígenes permitidos por CORS, separados por coma
# Dev:  http://localhost:3001,http://localhost:3002
# Prod: https://app.nikolator.com,https://nikolator.com
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# Sentry DSN para tracking de errores en producción (opcional)
SENTRY_DSN=
